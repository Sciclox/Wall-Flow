<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="Window" x:Key="WallFlowWindow">
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="ResizeMode" Value="NoResize" />
        <Setter Property="AllowsTransparency" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="Border" x:Key="ImageTile">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.3" Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="FrostedScrollBar" TargetType="ScrollBar">
        <Grid Background="Transparent">
            <Track x:Name="PART_Track">
                <Track.Thumb>
                    <Thumb>
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="#30FFFFFF"
                                        BorderBrush="#50FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Height="4" />
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template" Value="{StaticResource FrostedScrollBar}" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <ScrollContentPresenter CanContentScroll="True"
                                                 Margin="{TemplateBinding Padding}" />
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Bottom"
                                   Height="8"
                                   Margin="20,0,20,4"
                                   Minimum="0"
                                   Maximum="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ScrollableWidth, Mode=OneWay}"
                                   Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HorizontalOffset, Mode=OneWay}"
                                   ViewportSize="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ViewportWidth, Mode=OneWay}"
                                   Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ComputedHorizontalScrollBarVisibility, Mode=OneWay}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
