<Window x:Class="WallFlow.Windows.OnlineGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        ShowInTaskbar="False" Topmost="True"
        Background="Transparent"
        Width="860" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border CornerRadius="14" Background="#2D2D2D" BorderBrush="#404040" BorderThickness="1" Padding="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.6" BlurRadius="24" ShadowDepth="8" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar: source toggle + search -->
            <Border Grid.Row="0" CornerRadius="10" Background="#1E1E1E" BorderBrush="#404040" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Source toggle -->
                    <Border Grid.Column="0" x:Name="SourceToggle" CornerRadius="8" Background="#2A2A2A" BorderBrush="#505050" BorderThickness="1" Padding="4" Margin="4,0,12,0" Cursor="Hand" MouseLeftButtonUp="SourceToggle_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="LocalTab" CornerRadius="6" Padding="10,5" Background="#3D3D3D" Margin="1">
                                <TextBlock x:Name="LocalText" Text="Local" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                            </Border>
                            <Border Grid.Column="1" x:Name="OnlineTab" CornerRadius="6" Padding="10,5" Background="Transparent" Margin="1">
                                <TextBlock x:Name="OnlineText" Text="Online" FontFamily="Segoe UI" FontSize="13" FontWeight="Normal" Foreground="#888888" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Search box -->
                    <Border Grid.Column="1" CornerRadius="8" Background="#1A1A1A" BorderBrush="#404040" BorderThickness="1" Padding="4" Margin="0,0,12,0">
                        <Grid>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#666666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <TextBox x:Name="SearchBox" FontFamily="Segoe UI" FontSize="14" Foreground="White"
                                     Background="Transparent" BorderThickness="0" Padding="30,5,6,5"
                                     CaretBrush="White" IsTabStop="False"
                                     TextChanged="SearchBox_TextChanged" />
                        </Grid>
                    </Border>

                    <!-- Close button -->
                    <Border Grid.Column="2" x:Name="CloseBtn" Width="32" Height="32" CornerRadius="8" Background="Transparent"
                            Cursor="Hand" MouseLeftButtonUp="CloseBtn_Click" MouseEnter="CloseBtn_MouseEnter" MouseLeave="CloseBtn_MouseLeave">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#AAAAAA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- Gallery grid / detail panel -->
            <Grid Grid.Row="1">
                <!-- Gallery view -->
                <Grid x:Name="GalleryView" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent" Padding="2">
                        <ItemsControl x:Name="WallpaperGrid" Background="Transparent">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Detail view -->
                <Grid x:Name="DetailView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Detail header -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="BackBtn" CornerRadius="8" Padding="10,6" Background="#3D3D3D"
                                Cursor="Hand" MouseLeftButtonUp="BackBtn_Click" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Volver" FontFamily="Segoe UI" FontSize="13" Foreground="White" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <TextBlock Grid.Column="1" x:Name="DetailTitle" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="2" x:Name="ViewOnlineBtn" CornerRadius="8" Padding="10,6" Background="#3D3D3D"
                                Cursor="Hand" MouseLeftButtonUp="ViewOnline_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Ver online" FontFamily="Segoe UI" FontSize="13" Foreground="White" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Preview image -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Border CornerRadius="10" Background="#1A1A1A" BorderBrush="#404040" BorderThickness="1"
                                ClipToBounds="True">
                            <Border x:Name="PreviewBorder" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border.Background>
                                    <ImageBrush x:Name="PreviewBrush" Stretch="Uniform" />
                                </Border.Background>
                            </Border>
                        </Border>
                        <TextBlock x:Name="LoadingText" Text="Cargando..." FontFamily="Segoe UI" FontSize="16"
                                   Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                    </Grid>

                    <!-- Detail actions -->
                    <Border Grid.Row="2" CornerRadius="10" Background="#1E1E1E" BorderBrush="#404040" BorderThickness="1" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Resolution selector -->
                            <Border Grid.Column="0" CornerRadius="6" Background="#2A2A2A" BorderBrush="#505050" BorderThickness="1" Padding="4" Margin="0,0,12,0">
                                <ComboBox x:Name="ResolutionCombo" FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                          Background="#2A2A2A" BorderThickness="0"
                                          MinWidth="90" SelectedIndex="0">
                                    <ComboBox.Items>
                                        <ComboBoxItem Content="4K" Tag="4k" />
                                        <ComboBoxItem Content="2K" Tag="2k" />
                                        <ComboBoxItem Content="HD" Tag="hd" />
                                        <ComboBoxItem Content="Phone 4K" Tag="phone-4k" />
                                        <ComboBoxItem Content="Phone HD" Tag="phone-hd" />
                                    </ComboBox.Items>
                                </ComboBox>
                            </Border>

                            <!-- Apply button -->
                            <Border Grid.Column="2" x:Name="ApplyBtn" CornerRadius="8" Padding="14,8" Background="#4A6FA5"
                                    Cursor="Hand" MouseLeftButtonUp="ApplyBtn_Click" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Aplicar" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Save button -->
                            <Border Grid.Column="3" x:Name="SaveBtn" CornerRadius="8" Padding="14,8" Background="#3D3D3D"
                                    Cursor="Hand" MouseLeftButtonUp="SaveBtn_Click" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Guardar" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Status text -->
                            <TextBlock Grid.Column="4" x:Name="StatusText" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#888888" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Footer: pagination -->
            <Border Grid.Row="2" x:Name="FooterBar" CornerRadius="10" Background="#1E1E1E" BorderBrush="#404040" BorderThickness="1" Padding="8" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" x:Name="PrevBtn" CornerRadius="6" Padding="12,5" Background="#3D3D3D"
                            Cursor="Hand" MouseLeftButtonUp="PrevBtn_Click" IsEnabled="False">
                        <TextBlock Text="&#xE76B; Anterior" FontFamily="Segoe UI" FontSize="13" Foreground="#AAAAAA" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Column="1" x:Name="PageText" Text="Página 1 de 1" FontFamily="Segoe UI" FontSize="13"
                               Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <Border Grid.Column="2" x:Name="NextBtn" CornerRadius="6" Padding="12,5" Background="#3D3D3D"
                            Cursor="Hand" MouseLeftButtonUp="NextBtn_Click" IsEnabled="False">
                        <TextBlock Text="Siguiente &#xE76C;" FontFamily="Segoe UI" FontSize="13" Foreground="#AAAAAA" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
