<Window x:Class="WallFlow.Windows.OnlineGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None"
        ShowInTaskbar="False" Topmost="True"
        Background="#1A1A1A"
        Width="860" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0"
                            CornerRadius="12"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="Accent">#5B7FB5</Color>
        <Color x:Key="AccentHover">#6D91C7</Color>
        <Color x:Key="Surface">#252525</Color>
        <Color x:Key="SurfaceAlt">#1E1E1E</Color>
        <Color x:Key="Border">#333333</Color>
        <Color x:Key="TextPrimary">White</Color>
        <Color x:Key="TextSecondary">#999999</Color>
        <Color x:Key="TextMuted">#666666</Color>
        <Color x:Key="Danger">#C74B4B</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAlt}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />

        <!-- Shadows -->
        <DropShadowEffect x:Key="TileShadow" BlurRadius="8" Opacity="0.35" ShadowDepth="2" Color="Black" />
        <DropShadowEffect x:Key="ElevatedShadow" BlurRadius="16" Opacity="0.4" ShadowDepth="4" Color="Black" />

        <!-- ComboBox toggle button (transparent full-area background) -->
        <ControlTemplate x:Key="DarkComboToggleButton" TargetType="ToggleButton">
            <Border Background="{TemplateBinding Background}" CornerRadius="6" />
        </ControlTemplate>

        <!-- ComboBox dark template (click anywhere to open) -->
        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <Border x:Name="MainBorder" CornerRadius="6"
                        Background="Transparent"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Full-area toggle button (spans both columns) -->
                        <ToggleButton Grid.ColumnSpan="2" x:Name="ToggleButton"
                            Template="{StaticResource DarkComboToggleButton}"
                            IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                            ClickMode="Press" Focusable="False"
                            Background="Transparent" />

                        <!-- Content + chevron on top (not interactive) -->
                        <ContentPresenter Grid.Column="0"
                            Margin="8,4,4,4"
                            Content="{TemplateBinding SelectionBoxItem}"
                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                            ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            IsHitTestVisible="False" />
                        <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                   Width="26" IsHitTestVisible="False"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Popup x:Name="Popup" AllowsTransparency="True"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       Placement="Bottom" Focusable="False"
                       PopupAnimation="Fade">
                    <Grid MinWidth="{TemplateBinding ActualWidth}">
                        <Border CornerRadius="6" Background="#252525"
                                BorderBrush="#333333" BorderThickness="1"
                                Margin="0,4,0,0"
                                Effect="{StaticResource ElevatedShadow}">
                            <ScrollViewer>
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

    </Window.Resources>

    <Border CornerRadius="12" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ─── Top bar ─── -->
            <Border Grid.Row="0" CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Source toggle -->
                    <Border Grid.Column="0" x:Name="SourceToggle" CornerRadius="6" Background="#2D2D2D"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="3" Margin="4,0,12,0" Cursor="Hand"
                            MouseLeftButtonUp="SourceToggle_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Local tab -->
                            <Border Grid.Column="0" x:Name="LocalTab" CornerRadius="4" Padding="12,5" Background="#3D3D3D" Margin="1">
                                <TextBlock x:Name="LocalText" Text="Local" FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White" />
                            </Border>
                            <!-- Online tab -->
                            <Border Grid.Column="1" x:Name="OnlineTab" CornerRadius="4" Padding="12,5" Background="Transparent" Margin="1">
                                <TextBlock x:Name="OnlineText" Text="Online" FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="Normal" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Search box -->
                    <Border Grid.Column="1" CornerRadius="6" Background="#181818"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <TextBox Grid.Column="0" x:Name="SearchBox" FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                     Background="Transparent" BorderThickness="0" Padding="28,5,6,5"
                                     CaretBrush="White" IsTabStop="False"
                                     TextChanged="SearchBox_TextChanged" />
                            <Border Grid.Column="1" x:Name="SearchClearBtn" Width="24" Height="24" CornerRadius="4"
                                    Background="Transparent" Cursor="Hand" Visibility="Collapsed"
                                    MouseLeftButtonUp="SearchClearBtn_Click"
                                    Margin="0,0,4,0">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Close button -->
                    <Border Grid.Column="2" x:Name="CloseBtn" Width="30" Height="30" CornerRadius="6" Background="Transparent"
                            Cursor="Hand" MouseLeftButtonUp="CloseBtn_Click"
                            MouseEnter="CloseBtn_MouseEnter" MouseLeave="CloseBtn_MouseLeave">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- ─── Gallery / Detail ─── -->
            <Grid Grid.Row="1">
                <!-- Gallery view -->
                <Grid x:Name="GalleryView" Visibility="Visible">
                    <Grid>
                        <ListBox x:Name="WallpaperListBox" Background="Transparent" BorderThickness="0"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Standard"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Loading overlay -->
                        <Border x:Name="LoadingOverlay" Background="#CC1A1A1A" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ProgressBar x:Name="Spinner" IsIndeterminate="True" Width="180" Height="3"
                                             Foreground="{StaticResource AccentBrush}" Background="#333333"
                                             BorderThickness="0" Margin="0,0,0,14" />
                                <TextBlock Text="Cargando..." FontFamily="Segoe UI" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Empty overlay -->
                        <Border x:Name="EmptyOverlay" Background="#CC1A1A1A" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="44"
                                           Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,14" />
                                <TextBlock x:Name="EmptyText" Text="No se encontraron wallpapers"
                                           FontFamily="Segoe UI" FontSize="15"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Detail view -->
                <Grid x:Name="DetailView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Detail header -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" x:Name="BackBtn" CornerRadius="6" Padding="10,6"
                                Background="#2D2D2D" Cursor="Hand"
                                MouseLeftButtonUp="BackBtn_Click" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Volver" FontFamily="Segoe UI" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Column="1" x:Name="DetailTitle" FontFamily="Segoe UI" FontSize="15"
                                   FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <Border Grid.Column="2" x:Name="ViewOnlineBtn" CornerRadius="6" Padding="10,6"
                                Background="#2D2D2D" Cursor="Hand"
                                MouseLeftButtonUp="ViewOnline_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Ver online" FontFamily="Segoe UI" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Preview image -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Border CornerRadius="8" Background="#111111"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                ClipToBounds="True">
                            <Grid>
                                <Border x:Name="PreviewBorder" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Border.Background>
                                        <ImageBrush x:Name="PreviewBrush" Stretch="Uniform" />
                                    </Border.Background>
                                </Border>
                                <!-- Inner shadow overlay -->
                                <Border IsHitTestVisible="False" CornerRadius="8" BorderThickness="1">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="Black" Opacity="0.25" />
                                    </Border.BorderBrush>
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="LoadingText" Text="Cargando..." FontFamily="Segoe UI" FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                    </Grid>

                    <!-- Detail actions -->
                    <Border Grid.Row="2" CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Resolution selector -->
                            <ComboBox x:Name="ResolutionCombo" FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                      Background="Transparent" BorderBrush="#333333" BorderThickness="1"
                                      MinWidth="100" SelectedIndex="0"
                                      Template="{StaticResource DarkComboBoxTemplate}">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#252525" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#CCCCCC" />
                                </ComboBox.Resources>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#252525" />
                                        <Setter Property="Foreground" Value="#CCCCCC" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Padding" Value="8,4" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3D3D3D" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#555555" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBox.Items>
                                    <ComboBoxItem Content="4K" Tag="4k" />
                                    <ComboBoxItem Content="2K" Tag="2k" />
                                    <ComboBoxItem Content="HD" Tag="hd" />
                                    <ComboBoxItem Content="Phone 4K" Tag="phone-4k" />
                                    <ComboBoxItem Content="Phone HD" Tag="phone-hd" />
                                </ComboBox.Items>
                            </ComboBox>

                            <!-- Apply button -->
                            <Border Grid.Column="1" x:Name="ApplyBtn" CornerRadius="6" Padding="14,7"
                                    Background="{StaticResource AccentBrush}" Cursor="Hand"
                                    MouseLeftButtonUp="ApplyBtn_Click" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White"
                                               VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Aplicar" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Save button -->
                            <Border Grid.Column="2" x:Name="SaveBtn" CornerRadius="6" Padding="14,7"
                                    Background="#2D2D2D" Cursor="Hand"
                                    MouseLeftButtonUp="SaveBtn_Click" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White"
                                               VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Guardar" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Status text (right-aligned via star spacer) -->
                            <TextBlock Grid.Column="4" x:Name="StatusText" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ─── Footer: sort + pagination ─── -->
            <Border Grid.Row="2" x:Name="FooterBar" CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Sort dropdown -->
                    <ComboBox x:Name="SortCombo" FontFamily="Segoe UI" FontSize="13" Foreground="White"
                              Background="Transparent" BorderBrush="#333333" BorderThickness="1"
                              MinWidth="120" Margin="0,0,12,0"
                              SelectionChanged="SortCombo_SelectionChanged"
                              Template="{StaticResource DarkComboBoxTemplate}">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#252525" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#CCCCCC" />
                        </ComboBox.Resources>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#252525" />
                                <Setter Property="Foreground" Value="#CCCCCC" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="8,4" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3D3D3D" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#555555" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.Items>
                            <ComboBoxItem Content="Nombre &#x2191;" Tag="name-asc" />
                            <ComboBoxItem Content="Nombre &#x2193;" Tag="name-desc" />
                            <ComboBoxItem Content="Fecha &#x2191;" Tag="date-asc" />
                            <ComboBoxItem Content="Fecha &#x2193;" Tag="date-desc" />
                            <ComboBoxItem Content="Tamaño &#x2191;" Tag="size-asc" />
                            <ComboBoxItem Content="Tamaño &#x2193;" Tag="size-desc" />
                        </ComboBox.Items>
                    </ComboBox>

                    <!-- Pagination segmented control -->
                    <Border Grid.Column="1" x:Name="PaginationGroup" CornerRadius="6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Background="#2D2D2D" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Prev -->
                            <Border Grid.Column="0" x:Name="PrevBtn" Padding="10,4" Background="Transparent"
                                    Cursor="Hand" IsEnabled="False"
                                    MouseLeftButtonUp="PrevBtn_Click">
                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </Border>

                            <!-- Separator -->
                            <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderBrush}" Margin="0,4" />

                            <!-- Page text -->
                            <TextBlock Grid.Column="1" x:Name="PageText" Text="Página 1 de 1"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Padding="10,4" />

                            <!-- Separator -->
                            <Rectangle Grid.Column="2" Width="1" Fill="{StaticResource BorderBrush}" Margin="0,4" />

                            <!-- Next -->
                            <Border Grid.Column="2" x:Name="NextBtn" Padding="10,4" Background="Transparent"
                                    Cursor="Hand" IsEnabled="False"
                                    MouseLeftButtonUp="NextBtn_Click">
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="4" x:Name="FooterStatus" FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
